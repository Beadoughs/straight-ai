# Calendly (booking page)
NEXT_PUBLIC_CALENDLY_URL=https://calendly.com/your-team/intro-call

# Voiceflow web chat (official embed; injected in app/layout via components/voiceflow-widget.tsx)
# Required: Dashboard → your agent → copy Project ID
NEXT_PUBLIC_VOICEFLOW_PROJECT_ID=
# Optional: pin a published environment (alias from Settings → Environments), e.g. production
# NEXT_PUBLIC_VOICEFLOW_VERSION_ID=production

# Pick at most one other chat provider (Voiceflow is separate):

# Crisp (https://crisp.chat): Settings → Website ID
# NEXT_PUBLIC_CRISP_WEBSITE_ID=

# Or any provider that loads from a single script URL
# NEXT_PUBLIC_CHATBOT_SCRIPT_URL=
# NEXT_PUBLIC_CHATBOT_WIDGET_ID=
